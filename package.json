  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "npm run check-lint --fix && npx prettier --write .",
    "check-types": "tsc --pretty --noEmit",
